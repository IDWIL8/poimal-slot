rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == "ingatkachuk8@gmail.com";
    }

    function bookingFor(token) {
      return get(/databases/$(database)/documents/bookings/$(token));
    }

    function identityFor(personKey) {
      return get(/databases/$(database)/documents/bookingIdentities/$(personKey));
    }

    // Public clients subscribe to occupied slots and the participant names shown in the schedule.
    match /slotClaims/{slotId} {
      allow read: if true;
      allow create: if isAdmin() || (!exists(/databases/$(database)/documents/slotClaims/$(slotId))
        && request.resource.data.keys().hasOnly(['personKey', 'bookedBy', 'createdAt'])
        && request.resource.data.bookedBy is string
        && request.resource.data.bookedBy.size() >= 2
        && existsAfter(/databases/$(database)/documents/bookingIdentities/$(request.resource.data.personKey))
        && getAfter(/databases/$(database)/documents/bookingIdentities/$(request.resource.data.personKey)).data.slotId == slotId);
      allow update: if isAdmin();
      allow delete: if isAdmin()
        || bookingFor(identityFor(resource.data.personKey).data.token).data.personKey == resource.data.personKey;
    }

    // One deterministic SHA-256 identity document prevents duplicate bookings.
    match /bookingIdentities/{personKey} {
      allow read: if isAdmin();
      allow create: if isAdmin() || (!exists(/databases/$(database)/documents/bookingIdentities/$(personKey))
        && request.resource.data.keys().hasOnly(['token', 'slotId', 'createdAt']));
      allow update: if isAdmin() || (
        request.resource.data.token == resource.data.token
        && bookingFor(resource.data.token).data.personKey == personKey
      );
      allow delete: if isAdmin()
        || bookingFor(resource.data.token).data.personKey == personKey;
    }

    // A random document ID is the unguessable personal management token.
    // Listing is admin-only; direct get/update is possible only with that exact ID.
    match /bookings/{token} {
      allow list: if isAdmin();
      allow get: if true;
      allow create: if request.resource.data.token == token
        && request.resource.data.keys().hasAll(['token', 'slotId', 'fullName', 'team', 'personKey'])
        && request.resource.data.fullName is string
        && request.resource.data.fullName.size() >= 2
        && request.resource.data.team is string
        && request.resource.data.team.size() >= 2;
      allow update: if isAdmin() || (
        request.resource.data.token == resource.data.token
        && request.resource.data.personKey == resource.data.personKey
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['slotId', 'fullName', 'team', 'developmentGoal', 'status', 'cancelledAt', 'updatedAt'])
      );
      allow delete: if false;
    }

    match /adminNotes/{token} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
